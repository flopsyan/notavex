# Copy to .env (or set these in your shell / compose file) to configure Notavex.

# Bootstraps the login password on the FIRST start. It is then stored hashed in
# the data dir (auth.json) and can be changed in the app under "Account", after
# which this variable is ignored. Leave empty/unset AND with no stored password
# to run WITHOUT auth. (To reset a forgotten password: delete auth.json, set this.)
NOTAVEX_PASSWORD=

# Address to listen on.
NOTAVEX_ADDR=:8080

# Directory for the notes file (notavex.json), password hash (auth.json) and
# session secret (.secret). Point this at a bind-mounted NAS path to keep data
# on your NAS (see the "Storing the data on a NAS" section of the README).
NOTAVEX_DATA_DIR=data

# Set to "true" when Notavex is served over HTTPS so the session cookie is Secure.
NOTAVEX_SECURE=false

# Optional fixed session signing secret. If unset, a random one is generated
# and stored in NOTAVEX_DATA_DIR/.secret (sessions then survive restarts already).
# NOTAVEX_SECRET=
