# Copy to .env (or set these in your shell / compose file) to configure Jot.

# Require a login with this password. Leave empty/unset to run WITHOUT auth.
JOT_PASSWORD=

# Address to listen on.
JOT_ADDR=:8080

# Directory for the notes file (jot.json) and session secret (.secret).
JOT_DATA_DIR=data

# Set to "true" when Jot is served over HTTPS so the session cookie is Secure.
JOT_SECURE=false

# Optional fixed session signing secret. If unset, a random one is generated
# and stored in JOT_DATA_DIR/.secret (sessions then survive restarts already).
# JOT_SECRET=
