# Copy to .env (or set these in your shell / compose file) to configure Notavex.

# On the FIRST start these bootstrap the admin account: username NOTAVEX_USER
# (default "admin") with password NOTAVEX_PASSWORD. Accounts are then stored in
# the data dir (users.json) and managed in the app — admins add/remove users
# under Settings, everyone can change their own password — so these vars are
# ignored afterwards. Leave NOTAVEX_PASSWORD empty AND with no account to run
# WITHOUT a login. Once an account exists a login is required and nothing is
# shown until you sign in.
NOTAVEX_USER=admin
NOTAVEX_PASSWORD=

# Address to listen on.
NOTAVEX_ADDR=:8080

# Directory for the notes (notavex.json), accounts (users.json) and session
# secret (.secret). Point this at a bind-mounted NAS path to keep data on your
# NAS (see the "Storing the data on a NAS" section of the README).
NOTAVEX_DATA_DIR=data

# Set to "true" when Notavex is served over HTTPS so the session cookie is Secure.
NOTAVEX_SECURE=false

# Optional fixed session signing secret. If unset, a random one is generated
# and stored in NOTAVEX_DATA_DIR/.secret (sessions then survive restarts already).
# NOTAVEX_SECRET=
