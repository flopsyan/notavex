# Notavex configuration.
# Copy this file to ".env" and adjust the values. Docker Compose reads ".env"
# automatically, so `docker compose up -d --build` picks these up.

# --- Login -------------------------------------------------------------------
# On the FIRST start NOTAVEX_PASSWORD bootstraps the admin account (username
# NOTAVEX_USER, default "admin"). Accounts then live in the data dir (users.json)
# and are managed in the app under Settings, so the value is ignored afterwards.
# Leave NOTAVEX_PASSWORD EMPTY and with no account to run WITHOUT a login. Once an
# account exists a login is required and nothing is shown until you sign in.
NOTAVEX_USER=admin
NOTAVEX_PASSWORD=

# Host port Notavex is reachable on (http://localhost:NOTAVEX_PORT).
NOTAVEX_PORT=8080

# Set to "true" when Notavex is served over HTTPS so the session cookie is Secure.
NOTAVEX_SECURE=false

# Optional fixed session signing secret. If empty, a random one is generated and
# stored in the data dir (.secret), so sessions already survive restarts.
NOTAVEX_SECRET=

# --- Only when running WITHOUT Docker (the binary / `go run .`) ---------------
# Address to listen on, and the directory for notes, accounts and the secret.
# With Docker these are fixed to ":8080" and the /data volume, so leave them be.
# NOTAVEX_ADDR=:8080
# NOTAVEX_DATA_DIR=data
